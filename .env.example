# Copy to .env for local testing — never commit .env
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# LLM filter — get key from https://openrouter.ai/keys
# If not set, falls back to keyword-based filter
OPENROUTER_API_KEY=sk-or-v1-...

# Comma-separated keywords
JOB_KEYWORDS=meta ads,meta ads specialist,meta ads executive,meta ads manager,meta ads expert,meta ads freelancer,ppc,google ads,google ads specialist,google ads freelancer,google ads executive

COUNTRY_INDEED=india
IS_REMOTE=true
RESULTS_PER_KW=10
MAX_SLACK_JOBS=15
HOURS_OLD=26
